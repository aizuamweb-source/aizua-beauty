# ============================================================
# AIZUA — Variables de Entorno
# Copia este archivo como .env.local para desarrollo
# En producción: añadir en Vercel Dashboard → Settings → Environment Variables
# ============================================================
# ⚠️  NUNCA subas este archivo a GitHub (.gitignore debe incluir .env.local)

# ── STRIPE ──
# Obtener en: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Obtener en: Stripe Dashboard → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── SUPABASE ──
# Obtener en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── RESEND (email transaccional) ──
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=Aizua <onboarding@resend.dev>    # Fase pruebas — cambiar a pedidos@aizua.com cuando tengas el dominio

# ── KLAVIYO (email marketing) ──
# Obtener en: https://www.klaviyo.com/account#api-keys-tab
KLAVIYO_API_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXX
KLAVIYO_LIST_ID=XXXXXX

# ── N8N (orquestador de agentes) ──
# Tu instancia de n8n (Railway, Render, o self-hosted)
N8N_DSERS_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/dsers-fulfillment
N8N_EMAIL_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/send-email

# ── TELEGRAM BOT (alertas) ──
# BotFather en Telegram para crear el bot
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=XXXXXXXXXX

# ── APP ──
NEXT_PUBLIC_APP_URL=https://aizua.vercel.app       # Cambiar a https://aizua.com cuando tengas el dominio
NEXT_PUBLIC_APP_NAME=Aizua

# ── GOOGLE ANALYTICS ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── META PIXEL ──
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ── TIKTOK PIXEL ──
NEXT_PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ── CLOUDINARY (imágenes CDN) ──
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=aizua
CLOUDINARY_API_KEY=XXXXXXXXXXXXXXXXXX
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── DESARROLLO ──
# Stripe CLI para webhooks en local: stripe listen --forward-to localhost:3000/api/webhook
# Supabase local: npx supabase start
