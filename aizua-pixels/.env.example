# ============================================================
# AIZUA — .env.example COMPLETO
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub
# ============================================================

# ── APP ──
NEXT_PUBLIC_APP_URL=http://localhost:3000   # En producción: https://aizua.vercel.app (→ https://aizua.com cuando tengas el dominio)

# ── SUPABASE ──
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PROJECT_ID=XXXXXXXXXXXX

# ── STRIPE ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # pk_test_... en desarrollo
STRIPE_SECRET_KEY=your_stripe_secret_key_here    # sk_live_... en producción, sk_test_... en desarrollo
STRIPE_WEBHOOK_SECRET=whsec_...

# ── RESEND ──
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Aizua <onboarding@resend.dev>    # Cambiar a pedidos@aizua.com cuando tengas el dominio

# ── ALIEXPRESS ──
ALI_APP_KEY=12345678
ALI_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
ALI_ACCESS_TOKEN=                    # Se gestiona via OAuth — dejar vacío

# ── ANALYTICS / PÍXELES ──
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# GA4 (se configura dentro de GTM, no necesita variable de entorno)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX   # Solo si usas GA4 directamente sin GTM

# Meta
META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
META_CAPI_TOKEN=EAAxxxxxxxx...       # Conversions API token (Meta Business)
META_TEST_EVENT_CODE=TEST12345       # Solo para testing, eliminar en producción

# TikTok
TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXX
TIKTOK_CAPI_TOKEN=xxxxxxxx...        # TikTok Events API token

# ── TELEGRAM ──
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789          # Tu chat ID personal

# ── N8N ──
SYNC_SECRET_TOKEN=genera_string_seguro_aqui_32chars
N8N_IMAGES_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/upload-images
N8N_TRANSLATE_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/translate-product
N8N_REVIEW_WEBHOOK_URL=https://tu-n8n.railway.app/webhook/request-review

# ── CLOUDINARY ──
CLOUDINARY_CLOUD_NAME=aizua
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
